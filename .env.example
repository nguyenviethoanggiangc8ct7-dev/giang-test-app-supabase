# ==================================================
# Supabase Demo App - Environment Variables Example
# ==================================================
# Copy file này thành .env (cho Docker) hoặc .env.local (cho dev local)
# cp .env.example .env

# --------------------------------------------------
# Supabase Configuration (BẮT BUỘC)
# --------------------------------------------------
# URL của Supabase instance (self-hosted hoặc cloud)
# Self-hosted example: http://your-server-ip:8000
# Supabase cloud example: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://your-supabase-host:8000

# Anon key - lấy từ Supabase Dashboard > Settings > API
# hoặc từ file docker-compose của Supabase self-hosted (ANON_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
